# Server
PORT=4000

# PostgreSQL
DATABASE_URL=postgresql://user:password@localhost:5432/jesta

# JWT
JWT_SECRET=
JWT_REFRESH_SECRET=

# Firebase Admin SDK
# Option 1: path to service account JSON file
GOOGLE_APPLICATION_CREDENTIALS=./firebase-service-account.json
# Option 2: individual fields (used if GOOGLE_APPLICATION_CREDENTIALS is not set)
# FIREBASE_PROJECT_ID=
# FIREBASE_PRIVATE_KEY=
# FIREBASE_CLIENT_EMAIL=

# CORS
# FRONTEND_URL=http://localhost:8081
